{
  "expo": {
    "name": "HudumaGuide TZ",
    "slug": "hudumaguide-tz",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "hudumaguide",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.hudumaguide.tz",
      "supportsTablet": true
    },
    "android": {
      "package": "com.hudumaguide.tz",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A7A55"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-status-bar",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#0A7A55",
          "imageWidth": 220
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ec512a7-d16b-4e3a-a962-20b54f72669c"
      }
    },
    "owner": "kadioko"
  }
}
